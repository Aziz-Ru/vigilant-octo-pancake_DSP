   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "# Define the exponential function e^(-t)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {},
   "outputs": [
