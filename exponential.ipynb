   ],
   "source": [
    "T=np.arange(-10,10)\n",
    "exp_t=np.exp(-T)\n",
    "plt.plot(T,exp_t)\n",
    "plt.xlabel('t')\n",
    "plt.ylabel('e^(-t)')\n",
    "plt.title('Exponential function e^(-t)')\n",
    "plt.show()\n"
   ]
  }
